{
  "id": "manga-translation",
  "name": "Manga Translation",
  "version": "1.0.0",
  "manifestURI": "https://raw.githubusercontent.com/branrgx/seanime-extensions/master/src/plugins/MangaTranslation/manifest.json",
  "language": "typescript",
  "type": "plugin",
  "description": "An example plugin",
  "author": "branrgx",
  "icon": "",
  "website": "https://github.com/branrgx",
  "readme": "",
  "notes": "",
  "lang": "multi",
  "payloadURI": "https://raw.githubusercontent.com/branrgx/seanime-extensions/master/src/plugins/MangaTranslation/main.ts",
  "plugin": {
    "version": "1",
    "permissions": {
      "scopes": ["storage"],
      "allow": {
        "networkAccess": {
          "allowedDomains": ["api.toriitranslate.com", "*"],
          "reasoning": "Download manga pages and send to Torii API"
        },
        "unsafeFlags": [
          {
            "flag": "dom-script-manipulation",
            "reason": "Set img.src with data URLs from Torii"
          }
        ]
      }
    }
  }
}
